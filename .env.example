# Pact shared environment template.
# Copy to .env and fill values received from the developer/operator.

# Runtime
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database and queues
DATABASE_URL=postgresql://pact:pact@localhost:5432/pact
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=pact

# Stellar / Soroban
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_DEPLOYER_SECRET_KEY=
STELLAR_SPONSOR_SECRET_KEY=
STELLAR_PROJECT_SECRET_KEY=
STELLAR_ISSUER_SECRET_KEY=
STELLAR_ATTESTOR_SECRET_KEY=

# Demo asset
DEMO_ASSET_CODE=PACTUSD
DEMO_ASSET_ISSUER_PUBLIC_KEY=
DEMO_ASSET_ISSUER_SECRET_KEY=
DEMO_ASSET_CONTRACT_ID=

# Contract IDs
POLICY_REGISTRY_CONTRACT_ID=
ROOT_REGISTRY_CONTRACT_ID=
NULLIFIER_REGISTRY_CONTRACT_ID=
VERIFIER_ADAPTER_CONTRACT_ID=
MILESTONE_ESCROW_CONTRACT_ID=
GATED_ASSET_CONTROLLER_CONTRACT_ID=
PACT_CONTRACT_SOURCE_ACCOUNT=

# Public frontend contract config
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_POLICY_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_ROOT_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_NULLIFIER_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_VERIFIER_ADAPTER_CONTRACT_ID=
NEXT_PUBLIC_MILESTONE_ESCROW_CONTRACT_ID=
NEXT_PUBLIC_DEMO_ASSET_CONTRACT_ID=

# API auth and service security
API_ADMIN_TOKEN=
JWT_SECRET=
ENCRYPTION_KEY_BASE64=
CORS_ORIGIN=http://localhost:3000

# Stripe test OAuth revenue proof
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_TEST_MODE=true
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_OAUTH_REDIRECT_URI=http://127.0.0.1:4000/api/integrations/stripe/oauth/callback
STRIPE_WEBHOOK_SECRET=
STRIPE_OAUTH_STATE_SECRET=
PAYMENT_PROOF_ENCRYPTION_KEY=
PUBLIC_API_BASE_URL=http://127.0.0.1:4000
WEB_PUBLIC_API_BASE_URL=http://127.0.0.1:4000
PROVER_URL=http://127.0.0.1:4001
STRIPE_REAL_CONNECTED_ACCOUNT_ID=

# Mock issuer and attestor
MOCK_DATA_ENABLED=true
KYC_ISSUER_ID=PACT_KYB_MOCK_ISSUER
KYC_ISSUER_PRIVATE_KEY=
MILESTONE_ATTESTOR_ID=PACT_MILESTONE_MOCK_ATTESTOR
MILESTONE_ATTESTOR_PRIVATE_KEY=

# ZK proving
ZK_STACK=circom
ZK_PROOF_SYSTEM=groth16
ZK_CURVE=bn254
PROVER_MODE=local
PROVER_HOST=127.0.0.1
PROVER_PORT=4001
PROVER_SERVICE_URL=http://localhost:4001
PROVER_ENABLE_WORKER=true
PTAU_PATH=./circuits/artifacts/powersOfTau28_hez_final_12.ptau
ELIGIBILITY_CIRCUIT_WASM_PATH=./circuits/eligibility-proof/build/eligibility-proof_js/eligibility-proof.wasm
ELIGIBILITY_ZKEY_PATH=./circuits/eligibility-proof/build/eligibility-proof_final.zkey
ELIGIBILITY_VKEY_PATH=./circuits/eligibility-proof/build/verification_key.json
MILESTONE_CIRCUIT_WASM_PATH=./circuits/milestone-unlock-proof/build/milestone-unlock-proof_js/milestone-unlock-proof.wasm
MILESTONE_ZKEY_PATH=./circuits/milestone-unlock-proof/build/milestone-unlock-proof_final.zkey
MILESTONE_VKEY_PATH=./circuits/milestone-unlock-proof/build/verification_key.json
PAYMENT_REVENUE_CIRCUIT_WASM_PATH=./circuits/payment-revenue-threshold-proof/build/payment-revenue-threshold-proof_js/payment-revenue-threshold-proof.wasm
PAYMENT_REVENUE_ZKEY_PATH=./circuits/payment-revenue-threshold-proof/build/payment-revenue-threshold-proof_final.zkey
PAYMENT_REVENUE_VKEY_PATH=./circuits/payment-revenue-threshold-proof/build/verification_key.json

# Indexer
INDEXER_ENABLED=true
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_START_LEDGER=
INDEXER_CURSOR_PATH=./.pact-indexer-cursor.json

# Deployment
WEB_DEPLOY_URL=
API_DEPLOY_URL=
PROVER_DEPLOY_URL=
