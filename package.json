{
  "name": "pact",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "zk:compile:eligibility": "bash circuits/scripts/compile-eligibility.sh",
    "zk:test:eligibility": "bash circuits/scripts/test-eligibility.sh",
    "zk:compile:milestone": "bash circuits/scripts/compile-milestone.sh",
    "zk:test:milestone": "bash circuits/scripts/test-milestone.sh",
    "zk:compile:payment-revenue": "bash circuits/scripts/compile-payment-revenue.sh",
    "zk:test:payment-revenue": "bash circuits/scripts/test-payment-revenue.sh",
    "zk:setup:dev-ptau": "bash circuits/scripts/ensure-dev-ptau.sh",
    "zk:prove:eligibility": "bash circuits/scripts/snarkjs-pipeline.sh eligibility all",
    "zk:prove:milestone": "bash circuits/scripts/snarkjs-pipeline.sh milestone all",
    "zk:prove:payment-revenue": "bash circuits/scripts/snarkjs-pipeline.sh payment-revenue all",
    "zk:test:proofs": "bash circuits/scripts/snarkjs-pipeline.sh eligibility all && bash circuits/scripts/snarkjs-pipeline.sh milestone all && bash circuits/scripts/snarkjs-pipeline.sh payment-revenue all",
    "seed:demo": "tsx scripts/seed/seed-demo.ts",
    "seed:marketplace": "tsx scripts/seed/seed-marketplace-demo.ts",
    "demo:happy-path": "tsx scripts/demo/run-happy-path.ts",
    "demo:attacks": "tsx scripts/demo/run-attack-cases.ts",
    "deploy:contracts": "tsx scripts/deploy/contracts.ts",
    "infra:up": "docker compose -f docker-compose.offchain.yml up -d postgres redis",
    "infra:down": "docker compose -f docker-compose.offchain.yml down",
    "deploy:offchain": "tsx scripts/deploy/offchain-services.ts --strict",
    "deploy:web": "tsx scripts/deploy/frontend-demo.ts"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "snarkjs": "^0.7.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
