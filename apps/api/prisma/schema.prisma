generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProgramStatus {
  Draft
  Active
  Paused
  Cancelled
  Completed
}

enum TrancheStatus {
  Locked
  Ready
  Released
  Cancelled
}

enum PolicyType {
  Eligibility
  Milestone
  AssetAction
}

enum PolicyStatus {
  Draft
  Active
  Paused
  Deprecated
}

enum RootType {
  Credential
  MilestoneMetrics
  Revocation
}

enum RootStatus {
  Pending
  Active
  Inactive
  Expired
}

enum CredentialStatus {
  Active
  Revoked
  Expired
}

enum MilestoneAttestationStatus {
  Pending
  Validated
  Rejected
  Published
}

enum ProofType {
  Eligibility
  MilestoneUnlock
  PaymentRevenueThreshold
}

enum ProofJobStatus {
  Queued
  Running
  Succeeded
  Failed
}

enum StartupProfileStatus {
  Draft
  Submitted
  Listed
  Archived
}

enum InvestmentPoolType {
  Investment
  Grant
}

enum InvestmentPoolStatus {
  Draft
  Open
  Closed
  Archived
}

enum PoolApplicationStatus {
  Submitted
  Reviewed
  Accepted
  Rejected
}

enum InvestmentCommitmentStatus {
  Pending
  Accepted
  Declined
}

enum AccountRole {
  Sponsor
  Project
  Investor
  Issuer
  Attestor
  Observer
  Admin
}

model WalletAccount {
  id        String   @id @default(uuid()) @db.Uuid
  wallet    String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles      WalletRole[]
  sessions   AuthSession[]
  challenges AuthChallenge[]
  startupProfiles StartupProfile[]
  investmentPools InvestmentPool[]
  startupPoolApplications StartupPoolApplication[]
  investmentCommitments InvestmentCommitment[]

  @@map("wallet_accounts")
}

model WalletRole {
  id              String      @id @default(uuid()) @db.Uuid
  walletAccountId String      @map("wallet_account_id") @db.Uuid
  role            AccountRole
  grantedByWallet String?     @map("granted_by_wallet")
  createdAt       DateTime    @default(now()) @map("created_at")

  account WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)

  @@unique([walletAccountId, role])
  @@index([role])
  @@map("wallet_roles")
}

model AuthChallenge {
  id              String         @id @default(uuid()) @db.Uuid
  walletAccountId String?        @map("wallet_account_id") @db.Uuid
  wallet          String
  message         String
  nonce           String         @unique
  walletProvider  String?        @map("wallet_provider")
  expiresAt       DateTime       @map("expires_at")
  consumedAt      DateTime?      @map("consumed_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  account WalletAccount? @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)

  @@index([wallet, expiresAt])
  @@map("auth_challenges")
}

model AuthSession {
  id              String    @id @default(uuid()) @db.Uuid
  walletAccountId String    @map("wallet_account_id") @db.Uuid
  tokenHash       String    @unique @map("token_hash")
  walletProvider  String?   @map("wallet_provider")
  expiresAt       DateTime  @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at")

  account WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)

  @@index([walletAccountId, expiresAt])
  @@map("auth_sessions")
}

model StartupProfile {
  id              String               @id @default(uuid()) @db.Uuid
  founderWallet   String               @map("founder_wallet")
  name            String
  summary         String
  industry        String
  stage           String
  website         String?
  requestedAmount Decimal              @map("requested_amount")
  currency        String               @default("USDC")
  fundingUse      String               @map("funding_use")
  requirements    String
  traction        String
  status          StartupProfileStatus @default(Submitted)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  founder WalletAccount @relation(fields: [founderWallet], references: [wallet], onDelete: Cascade)
  poolApplications StartupPoolApplication[]
  investmentCommitments InvestmentCommitment[]

  @@index([founderWallet, createdAt])
  @@index([status, createdAt])
  @@map("startup_profiles")
}

model InvestmentPool {
  id              String               @id @default(uuid()) @db.Uuid
  ownerWallet     String               @map("owner_wallet")
  name            String
  poolType        InvestmentPoolType   @map("pool_type")
  thesis          String
  targetIndustry  String               @map("target_industry")
  stages          String               @default("")
  totalAmount     Decimal              @map("total_amount")
  currency        String               @default("USDC")
  requirements    String
  status          InvestmentPoolStatus @default(Open)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  owner WalletAccount @relation(fields: [ownerWallet], references: [wallet], onDelete: Cascade)
  applications StartupPoolApplication[]

  @@index([ownerWallet, createdAt])
  @@index([status, poolType, createdAt])
  @@map("investment_pools")
}

model StartupPoolApplication {
  id               String                @id @default(uuid()) @db.Uuid
  founderWallet    String                @map("founder_wallet")
  startupProfileId String                @map("startup_profile_id") @db.Uuid
  investmentPoolId String                @map("investment_pool_id") @db.Uuid
  note             String
  status           PoolApplicationStatus @default(Submitted)
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  founder WalletAccount @relation(fields: [founderWallet], references: [wallet], onDelete: Cascade)
  startupProfile StartupProfile @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  investmentPool InvestmentPool @relation(fields: [investmentPoolId], references: [id], onDelete: Cascade)

  @@unique([startupProfileId, investmentPoolId])
  @@index([founderWallet, createdAt])
  @@index([investmentPoolId, status])
  @@map("startup_pool_applications")
}

model InvestmentCommitment {
  id               String                     @id @default(uuid()) @db.Uuid
  investorWallet   String                     @map("investor_wallet")
  startupProfileId String                     @map("startup_profile_id") @db.Uuid
  amount           Decimal
  currency         String                     @default("USDC")
  note             String
  status           InvestmentCommitmentStatus @default(Pending)
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")

  investor WalletAccount @relation(fields: [investorWallet], references: [wallet], onDelete: Cascade)
  startupProfile StartupProfile @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)

  @@index([investorWallet, createdAt])
  @@index([startupProfileId, status])
  @@map("investment_commitments")
}

model Program {
  id                  String   @id @default(uuid()) @db.Uuid
  programKey          String   @unique @map("program_key")
  sponsorWallet       String   @map("sponsor_wallet")
  projectWallet       String   @map("project_wallet")
  assetContract       String   @map("asset_contract")
  totalAmount         Decimal  @map("total_amount")
  fundedAmount        Decimal  @default(0) @map("funded_amount")
  status              ProgramStatus
  eligibilityPolicyId String   @map("eligibility_policy_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tranches              Tranche[]
  milestoneAttestations MilestoneAttestation[]
  stripeOAuthStates     StripeOAuthState[]
  stripeConnections     StripeConnection[]
  paymentRevenueSnapshots PaymentRevenueSnapshot[]

  @@map("programs")
}

model Tranche {
  id                String        @id @default(uuid()) @db.Uuid
  programId         String        @map("program_id") @db.Uuid
  milestoneKey      String        @map("milestone_key")
  milestonePolicyId String        @map("milestone_policy_id")
  amount            Decimal
  releaseToWallet   String        @map("release_to_wallet")
  status            TrancheStatus
  releasedAt        DateTime?     @map("released_at")
  txHash            String?       @map("tx_hash")

  program Program @relation(fields: [programId], references: [id])

  @@unique([programId, milestoneKey])
  @@map("tranches")
}

model Policy {
  id            String       @id @default(uuid()) @db.Uuid
  policyKey     String       @unique @map("policy_key")
  policyHash    String       @map("policy_hash")
  policyType    PolicyType   @map("policy_type")
  status        PolicyStatus
  rawPolicyJson Json         @map("raw_policy_json")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  roots Root[]

  @@map("policies")
}

model Root {
  id         String     @id @default(uuid()) @db.Uuid
  policyId   String     @map("policy_id") @db.Uuid
  root       String
  rootType   RootType   @map("root_type")
  epoch      Int
  status     RootStatus
  txHash     String?    @map("tx_hash")
  validFrom  DateTime   @map("valid_from")
  validUntil DateTime   @map("valid_until")
  createdAt  DateTime   @default(now()) @map("created_at")

  policy Policy @relation(fields: [policyId], references: [id])

  @@index([policyId, rootType, status])
  @@map("roots")
}

model Credential {
  id                String           @id @default(uuid()) @db.Uuid
  credentialKey     String           @unique @map("credential_key")
  wallet            String
  subjectCommitment String           @map("subject_commitment")
  issuerId          String           @map("issuer_id")
  credentialLeaf    String           @map("credential_leaf")
  status            CredentialStatus
  expiresAt         DateTime         @map("expires_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@index([wallet, status])
  @@map("credentials")
}

model MilestoneAttestation {
  id                      String                     @id @default(uuid()) @db.Uuid
  programId               String                     @map("program_id") @db.Uuid
  milestoneKey            String                     @map("milestone_key")
  milestoneRoot           String?                    @map("milestone_root")
  privateMetricsEncrypted String                     @map("private_metrics_encrypted")
  publicPolicyHash        String                     @map("public_policy_hash")
  attestorId              String                     @map("attestor_id")
  status                  MilestoneAttestationStatus
  txHash                  String?                    @map("tx_hash")
  createdAt               DateTime                   @default(now()) @map("created_at")

  program Program @relation(fields: [programId], references: [id])

  @@index([programId, milestoneKey, status])
  @@map("milestone_attestations")
}

model ProofJob {
  id               String         @id @default(uuid()) @db.Uuid
  proofType        ProofType      @map("proof_type")
  status           ProofJobStatus
  requestJson      Json           @map("request_json")
  publicInputsJson Json?          @map("public_inputs_json")
  proofJson        Json?          @map("proof_json")
  error            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  completedAt      DateTime?      @map("completed_at")

  @@index([proofType, status])
  @@map("proof_jobs")
}

model StripeConnection {
  id                String    @id @default(uuid()) @db.Uuid
  programId         String    @map("program_id") @db.Uuid
  stripeAccountId   String    @map("stripe_account_id")
  stripeAccountHash String    @map("stripe_account_hash")
  livemode          Boolean
  scope             String
  status            String
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deauthorizedAt    DateTime? @map("deauthorized_at")

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  snapshots PaymentRevenueSnapshot[]

  @@index([programId, status])
  @@map("stripe_connections")
}

model StripeOAuthState {
  id          String    @id @default(uuid()) @db.Uuid
  stateHash   String    @unique @map("state_hash")
  programId   String    @map("program_id") @db.Uuid
  redirectUri String    @map("redirect_uri")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, expiresAt])
  @@map("stripe_oauth_states")
}

model PaymentRevenueSnapshot {
  id                             String   @id @default(uuid()) @db.Uuid
  programId                      String   @map("program_id") @db.Uuid
  stripeConnectionId             String   @map("stripe_connection_id") @db.Uuid
  periodStart                    DateTime @map("period_start")
  periodEnd                      DateTime @map("period_end")
  currency                       String
  thresholdCents                 Decimal  @map("threshold_cents")
  grossPaidCentsEncrypted        String   @map("gross_paid_cents_encrypted")
  refundCentsEncrypted           String   @map("refund_cents_encrypted")
  feeCentsEncrypted              String   @map("fee_cents_encrypted")
  netRevenueCentsEncrypted       String   @map("net_revenue_cents_encrypted")
  successfulChargeCountEncrypted String   @map("successful_charge_count_encrypted")
  snapshotCommitment             String   @map("snapshot_commitment")
  sourceRefsCommitment           String   @map("source_refs_commitment")
  rawSourceRefsEncrypted         String   @map("raw_source_refs_encrypted")
  status                         String
  generatedAt                    DateTime @default(now()) @map("generated_at")

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  stripeConnection StripeConnection @relation(fields: [stripeConnectionId], references: [id], onDelete: Cascade)

  @@index([programId, generatedAt])
  @@index([stripeConnectionId])
  @@map("payment_revenue_snapshots")
}

model StripeWebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  stripeEventId   String    @unique @map("stripe_event_id")
  stripeAccountId String?   @map("stripe_account_id")
  type            String
  livemode        Boolean
  payloadHash     String    @map("payload_hash")
  receivedAt      DateTime  @default(now()) @map("received_at")
  processedAt     DateTime? @map("processed_at")

  @@index([stripeAccountId, type])
  @@map("stripe_webhook_events")
}

model ContractEvent {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @map("contract_id")
  eventType  String   @map("event_type")
  txHash     String   @map("tx_hash")
  ledger     Int
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([txHash, eventType])
  @@index([contractId, ledger])
  @@map("contract_events")
}
