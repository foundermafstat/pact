    "@stellar/stellar-sdk": "^14.6.1",
    "bullmq": "^5.66.1",
    "cookie": "^2.0.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "prisma": "^7.2.0"
